# App binding
MM_LAB_HOST=127.0.0.1
MM_LAB_PORT=7870
MM_LAB_UI_PATH=/
MM_LAB_API_PREFIX=/api

# Shared compare defaults
MM_LAB_DEFAULT_TIMEOUT_SECONDS=180
MM_LAB_DEFAULT_TARGET_HEIGHT=480
MM_LAB_DEFAULT_VIDEO_FPS=1.0
MM_LAB_SAFE_VIDEO_SAMPLING=0

# Model A defaults
MM_LAB_MODEL_A_LABEL=Qwen 3.5 27B FP8
MM_LAB_MODEL_A_BASE_URL=http://127.0.0.1:8000/v1
MM_LAB_MODEL_A_MODEL=Qwen/Qwen3.5-27B-FP8
MM_LAB_MODEL_A_API_KEY=EMPTY
MM_LAB_MODEL_A_DEFAULT_USE_MODEL_DEFAULTS=0
MM_LAB_MODEL_A_DEFAULT_MAX_TOKENS=10000
MM_LAB_MODEL_A_DEFAULT_MAX_COMPLETION_TOKENS=9500
MM_LAB_MODEL_A_DEFAULT_TEMPERATURE=1.0
MM_LAB_MODEL_A_DEFAULT_TOP_P=0.95
MM_LAB_MODEL_A_DEFAULT_TOP_K=20
MM_LAB_MODEL_A_DEFAULT_PRESENCE_PENALTY=1.5
MM_LAB_MODEL_A_DEFAULT_FREQUENCY_PENALTY=0.0
MM_LAB_MODEL_A_DEFAULT_THINKING_MODE=off
MM_LAB_MODEL_A_DEFAULT_SHOW_REASONING=0
MM_LAB_MODEL_A_DEFAULT_MEASURE_TTFT=1

# Model B defaults
MM_LAB_MODEL_B_LABEL=Gemma 4 31B FP8
MM_LAB_MODEL_B_BASE_URL=http://127.0.0.1:8001/v1
MM_LAB_MODEL_B_MODEL=RedHatAI/gemma-4-31B-it-FP8-block
MM_LAB_MODEL_B_API_KEY=EMPTY
MM_LAB_MODEL_B_DEFAULT_USE_MODEL_DEFAULTS=0
MM_LAB_MODEL_B_DEFAULT_MAX_TOKENS=10000
MM_LAB_MODEL_B_DEFAULT_MAX_COMPLETION_TOKENS=9500
MM_LAB_MODEL_B_DEFAULT_TEMPERATURE=1.0
MM_LAB_MODEL_B_DEFAULT_TOP_P=0.95
MM_LAB_MODEL_B_DEFAULT_TOP_K=64
MM_LAB_MODEL_B_DEFAULT_PRESENCE_PENALTY=1.5
MM_LAB_MODEL_B_DEFAULT_FREQUENCY_PENALTY=0.0
MM_LAB_MODEL_B_DEFAULT_THINKING_MODE=off
MM_LAB_MODEL_B_DEFAULT_SHOW_REASONING=0
MM_LAB_MODEL_B_DEFAULT_MEASURE_TTFT=1

# Persistence
MM_LAB_RESULTS_DIR=./visual_experimentation_app/results
